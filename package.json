{
  "dependencies": {
    "@cerebras/cerebras_cloud_sdk": "^1.64.1",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "webpack": "^5.106.0",
    "webpack-cli": "^7.0.2"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "node scripts/check-no-console-log.js",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write"
  }
}
